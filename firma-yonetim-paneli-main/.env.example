# Kalıcı PostgreSQL 17 (Windows servisi olarak otomatik çalışır, ayrıca başlatmak gerekmez)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/firma_yonetim"
# Yalnızca `prisma migrate dev` kullanır
SHADOW_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/firma_yonetim_shadow"

# Auth.js oturum imzalama anahtarı — üretmek için: openssl rand -base64 32
AUTH_SECRET="buraya-rastgele-bir-anahtar-uretin"
